---
import '../styles/global.css';
import { developer } from '../data/portfolio';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = `${developer.title} — ${developer.specialty}`,
  image = '/og-image.png',
  type = 'website',
} = Astro.props;

const ogTitle = title;
const ogDescription = description;
const ogImage = new URL(image, Astro.site ?? Astro.url).href;
const canonicalURL = Astro.url.href;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- SEO -->
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_PE" />
    <meta property="og:site_name" content={developer.name} />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=JetBrains+Mono:ital,wght@0,400;0,500&display=swap" rel="stylesheet">
  </head>
  <body class="antialiased selection:bg-accent selection:text-bg-dark flex flex-col min-h-screen">
    <slot />
  </body>
</html>
