---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Experience from '../components/Experience.astro';
import TechStack from '../components/TechStack.astro';
import Projects from '../components/Projects.astro';
import { developer } from '../data/portfolio';
---

<Layout title={`${developer.name} - ${developer.title}`}>
  <Header />
  <main class="max-w-5xl mx-auto px-8 w-full flex-grow">
    <Hero />
    <Experience />
    <TechStack />
    <Projects />
  </main>

  <footer class="py-8 border-t border-border-dark">
    <div class="max-w-5xl mx-auto px-8 flex items-center justify-between">
      <p class="font-mono text-[10px] text-neutral-700 uppercase tracking-[0.22em]">
        © {new Date().getFullYear()} {developer.name}
      </p>
      <p class="font-mono text-[10px] text-neutral-700 uppercase tracking-[0.22em]">
        Astro · Tailwind v4
      </p>
    </div>
  </footer>
</Layout>
