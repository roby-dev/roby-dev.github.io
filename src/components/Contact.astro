---
import { developer, socials } from "../data/portfolio";
import Icon from "./Icon.astro";
---

<section id="contacto" class="pt-24 pb-24 relative">
  <!-- Accent line animated -->
  <div class="h-px bg-accent mb-8 line-grow d1"></div>

  <!-- Label -->
  <p class="font-mono text-[11px] text-neutral-500 uppercase tracking-[0.38em] mb-6 fade-up d2">
    <span class="text-accent mr-3">04</span>Contacto
  </p>

  <!-- Heading -->
  <h2 class="font-display font-black text-white mb-12 fade-up d3" style="font-size: clamp(2rem, 5.5vw, 3.5rem); line-height: 0.95;">
    Trabajemos<br /><span class="text-accent">juntos</span>
  </h2>

  <!-- Direct contact block -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10 fade-up d4">
    <a href={`mailto:${developer.email}`} class="group block p-5 border border-border-dark hover:border-accent transition-colors duration-200">
      <div class="font-mono text-[10px] text-neutral-600 uppercase tracking-[0.22em] mb-2">Email</div>
      <div class="font-display text-base text-white group-hover:text-accent transition-colors duration-200 break-all">
        {developer.email}
      </div>
    </a>
  </div>

  <!-- Location strip -->
  <p class="font-mono text-[11px] text-neutral-500 tracking-[0.14em] uppercase mb-8 fade-up d5">
    Ubicado en {developer.location}
  </p>

  <!-- Socials block -->
  <div class="flex flex-wrap gap-3 fade-up d6">
    {
      socials.map((s) => (
        <a
          href={s.url}
          target={s.url.startsWith("mailto:") ? "_self" : "_blank"}
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 border border-border-dark font-mono text-[11px] text-neutral-500 tracking-[0.1em] hover:border-accent hover:text-accent transition-colors duration-200"
        >
          <Icon name={s.icon as 'github' | 'linkedin' | 'email'} size={14} />
          {s.label} ↗
        </a>
      ))
    }
  </div>
</section>
