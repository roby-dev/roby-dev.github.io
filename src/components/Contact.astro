---
import { developer, socials } from "../data/portfolio";
---

<section id="contacto" class="pt-24 pb-24 relative">
  <!-- Accent line animated -->
  <div class="h-px bg-accent mb-8 line-grow d1"></div>

  <!-- Label -->
  <p class="font-mono text-[11px] text-neutral-500 uppercase tracking-[0.38em] mb-6 fade-up d2">
    <span class="text-accent mr-3">04</span>Contacto
  </p>

  <!-- Heading -->
  <h2 class="font-display font-black text-white mb-12 fade-up d3" style="font-size: clamp(2rem, 5.5vw, 3.5rem); line-height: 0.95;">
    Trabajemos<br /><span class="text-accent">juntos</span>
  </h2>

  <!-- Direct contact block -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10 fade-up d4">
    <a href={`mailto:${developer.email}`} class="group block p-5 border border-border-dark hover:border-accent transition-colors duration-200">
      <div class="font-mono text-[10px] text-neutral-600 uppercase tracking-[0.22em] mb-2">Email</div>
      <div class="font-display text-base text-white group-hover:text-accent transition-colors duration-200 break-all">
        {developer.email}
      </div>
    </a>
  </div>

  <!-- Location strip -->
  <p class="font-mono text-[11px] text-neutral-500 tracking-[0.14em] uppercase mb-8 fade-up d5">
    Basado en {developer.location}
  </p>

  <!-- Socials block -->
  <div class="flex flex-wrap gap-3 fade-up d6">
    {
      socials.map((s) => (
        <a
          href={s.url}
          target={s.url.startsWith("mailto:") ? "_self" : "_blank"}
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-3 border border-border-dark font-mono text-[11px] text-neutral-500 tracking-[0.1em] hover:border-accent hover:text-accent transition-colors duration-200"
        >
          {s.icon === "github" && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
          )}
          {s.icon === "linkedin" && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          )}
          {s.icon === "email" && (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2" />
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
            </svg>
          )}
          {s.label} ↗
        </a>
      ))
    }
  </div>
</section>
