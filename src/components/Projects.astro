---
import { projects } from '../data/portfolio';

const personal = projects.filter(p => p.type === 'personal');
const professional = projects.filter(p => p.type === 'professional');
---
<section id="proyectos" class="py-24">

  <div class="flex items-center gap-5 mb-16">
    <span class="font-mono text-xs text-neutral-700 tracking-[0.32em]">03</span>
    <h2 class="font-display font-bold text-sm text-white tracking-[0.22em] uppercase">Proyectos</h2>
    <div class="flex-1 h-px bg-border-dark"></div>
  </div>

  <!-- Personal projects -->
  <div class="mb-12">
    <p class="font-mono text-[10px] text-accent uppercase tracking-[0.28em] mb-6">Personales</p>
    <div class="grid grid-cols-1 md:grid-cols-2 border-l border-t border-border-dark">
      {personal.map((project, index) => (
        <div class="group border-b border-r border-border-dark p-8 relative overflow-hidden hover:bg-accent/[0.028] transition-colors duration-300">

          <div
            class="absolute bottom-3 right-5 font-display font-black leading-none select-none pointer-events-none"
            style="font-size: 5rem; color: rgba(255,255,255,0.038);"
            aria-hidden="true"
          >
            {String(index + 1).padStart(2, '0')}
          </div>

          <div class="relative z-10">
            <div class="flex items-start justify-between gap-4 mb-3">
              <h3 class="font-display font-bold text-white group-hover:text-accent transition-colors duration-300 text-base leading-snug">
                {project.title}
              </h3>
              {project.github && (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-neutral-700 hover:text-accent transition-colors duration-200 shrink-0 mt-0.5"
                  aria-label={`Ver ${project.title} en GitHub`}
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                </a>
              )}
            </div>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-x-3 gap-y-1">
              {project.tech.map(tech => (
                <span class="font-mono text-[10px] text-neutral-700 uppercase tracking-[0.16em]">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-accent group-hover:w-full transition-all duration-500 ease-out"></div>
        </div>
      ))}
    </div>
  </div>

  <!-- Professional projects -->
  <div>
    <p class="font-mono text-[10px] text-neutral-600 uppercase tracking-[0.28em] mb-6">Caja Tacna</p>
    <div class="grid grid-cols-1 md:grid-cols-2 border-l border-t border-border-dark">
      {professional.map((project, index) => (
        <div class="group border-b border-r border-border-dark p-8 relative overflow-hidden hover:bg-white/[0.02] transition-colors duration-300">

          <div
            class="absolute bottom-3 right-5 font-display font-black leading-none select-none pointer-events-none"
            style="font-size: 5rem; color: rgba(255,255,255,0.028);"
            aria-hidden="true"
          >
            {String(index + 1).padStart(2, '0')}
          </div>

          <div class="relative z-10">
            <h3 class="font-display font-bold text-white group-hover:text-neutral-300 transition-colors duration-300 text-base mb-3 leading-snug">
              {project.title}
            </h3>
            <p class="text-sm text-neutral-600 leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-x-3 gap-y-1">
              {project.tech.map(tech => (
                <span class="font-mono text-[10px] text-neutral-700 uppercase tracking-[0.16em]">
                  {tech}
                </span>
              ))}
            </div>
          </div>

          <div class="absolute bottom-0 left-0 h-[2px] w-0 bg-neutral-700 group-hover:w-full transition-all duration-500 ease-out"></div>
        </div>
      ))}
    </div>
  </div>

</section>
