---
import { developer } from '../data/portfolio';
---
<header class="fixed top-0 z-50 w-full border-b border-border-dark">
  <div class="absolute inset-0 bg-bg-dark/90 backdrop-blur-md"></div>
  <div class="relative max-w-5xl mx-auto px-4 sm:px-8 h-14 flex items-center justify-between">

    <a href="#" class="font-display font-black text-sm tracking-[0.06em] text-white hover:text-accent transition-colors duration-200">
      RZ<span class="text-accent">.</span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex gap-8 font-mono text-[11px] text-neutral-500">
      <a href="#experiencia" class="hover:text-accent transition-colors duration-200 flex items-center gap-2">
        <span class="text-accent text-[9px]">01</span>
        <span class="tracking-[0.18em] uppercase">Experiencia</span>
      </a>
      <a href="#stack" class="hover:text-accent transition-colors duration-200 flex items-center gap-2">
        <span class="text-accent text-[9px]">02</span>
        <span class="tracking-[0.18em] uppercase">Stack</span>
      </a>
      <a href="#proyectos" class="hover:text-accent transition-colors duration-200 flex items-center gap-2">
        <span class="text-accent text-[9px]">03</span>
        <span class="tracking-[0.18em] uppercase">Proyectos</span>
      </a>
      <a href="#contacto" class="hover:text-accent transition-colors duration-200 flex items-center gap-2">
        <span class="text-accent text-[9px]">04</span>
        <span class="tracking-[0.18em] uppercase">Contacto</span>
      </a>
    </nav>

    <div class="flex items-center gap-4">
      <!-- Desktop social icons -->
      <a
        href={developer.github}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex text-neutral-600 hover:text-accent transition-colors duration-200"
        aria-label="GitHub"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href={developer.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex text-neutral-600 hover:text-accent transition-colors duration-200"
        aria-label="LinkedIn"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>

      <!-- Hamburger button (mobile only) -->
      <button
        id="nav-toggle"
        type="button"
        class="md:hidden inline-flex items-center justify-center w-9 h-9 text-neutral-400 hover:text-accent transition-colors duration-200"
        aria-controls="mobile-nav"
        aria-expanded="false"
        aria-label="Abrir menu"
      >
        <!-- Open icon (3 bars) -->
        <svg class="icon-open" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <line x1="2" y1="4.5" x2="16" y2="4.5" />
          <line x1="2" y1="9" x2="16" y2="9" />
          <line x1="2" y1="13.5" x2="16" y2="13.5" />
        </svg>
        <!-- Close icon (X) -->
        <svg class="icon-close hidden" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="3" x2="15" y2="15" />
          <line x1="15" y1="3" x2="3" y2="15" />
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile drawer (collapsed by default) -->
  <nav
    id="mobile-nav"
    class="md:hidden overflow-hidden bg-bg-dark/95 backdrop-blur-md border-t border-border-dark"
    style="max-height: 0;"
    aria-label="Navegacion movil"
  >
    <ul class="flex flex-col px-4 py-4 gap-4 font-mono text-[12px] uppercase tracking-[0.18em] text-neutral-400">
      <li>
        <a href="#experiencia" class="mobile-nav-link block py-2 hover:text-accent transition-colors duration-200">
          <span class="text-accent text-[10px] mr-3">01</span>Experiencia
        </a>
      </li>
      <li>
        <a href="#stack" class="mobile-nav-link block py-2 hover:text-accent transition-colors duration-200">
          <span class="text-accent text-[10px] mr-3">02</span>Stack
        </a>
      </li>
      <li>
        <a href="#proyectos" class="mobile-nav-link block py-2 hover:text-accent transition-colors duration-200">
          <span class="text-accent text-[10px] mr-3">03</span>Proyectos
        </a>
      </li>
      <li>
        <a href="#contacto" class="mobile-nav-link block py-2 hover:text-accent transition-colors duration-200">
          <span class="text-accent text-[10px] mr-3">04</span>Contacto
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('nav-toggle');
  const nav = document.getElementById('mobile-nav');
  const iconOpen = btn?.querySelector('.icon-open');
  const iconClose = btn?.querySelector('.icon-close');

  function setOpen(open: boolean) {
    if (!btn || !nav) return;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? 'Cerrar menu' : 'Abrir menu');
    nav.style.maxHeight = open ? nav.scrollHeight + 'px' : '0px';
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  }

  btn?.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  // Close on nav link click (in-page navigation)
  nav?.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') setOpen(false);
  });
</script>
