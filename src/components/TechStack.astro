---
import { techStack } from '../data/portfolio';
---
<section id="stack" class="py-24">

  <div class="flex items-center gap-5 mb-16">
    <span class="font-mono text-xs text-neutral-700 tracking-[0.32em]">02</span>
    <h2 class="font-display font-bold text-sm text-white tracking-[0.22em] uppercase">Stack Tecnológico</h2>
    <div class="flex-1 h-px bg-border-dark"></div>
  </div>

  <div>
    {techStack.map((category) => (
      <div class="border-t border-border-dark py-8 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 items-start">

        <div class="md:col-span-3">
          <span class="font-mono text-[10px] text-accent uppercase tracking-[0.28em]">
            {category.category}
          </span>
        </div>

        <div class="md:col-span-9 flex flex-wrap gap-2">
          {category.items.map(tech => (
            <span class="font-mono text-xs px-3 py-1.5 border border-border-dark text-neutral-500 hover:border-accent/60 hover:text-accent transition-colors duration-200 cursor-default">
              {tech}
            </span>
          ))}
        </div>

      </div>
    ))}
    <div class="border-t border-border-dark"></div>
  </div>

</section>
